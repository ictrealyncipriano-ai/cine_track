# Copy this file to .env and fill in your values
# For Vercel production: set these as Environment Variables in the dashboard

APP_URL=http://localhost/cine_track

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cinetracker
DB_USERNAME=root
DB_PASSWORD=

# CORS origin - set to your frontend domain in production, or * for development
CORS_ORIGIN=*

# TMDB API key for movie metadata fetching (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Mail configuration (optional, for password reset & email verification)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="CineTrack"
