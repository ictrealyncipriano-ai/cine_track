{
  "buildCommand": "bash build.sh",
  "outputDirectory": "build/web",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
